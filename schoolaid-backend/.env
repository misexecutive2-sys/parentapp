# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# ⚠️  Replace with a long random string before going live
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=DEMO_JWT_SECRET_REPLACE_BEFORE_LIVE
JWT_EXPIRES_IN=7d

# ─── SchoolAid License API ────────────────────────────────────────────────────
LICENSE_API_URL=https://staging.schoolaid.in/api/login/verify-license

# ⚠️  Set this to your real key when you receive it from SchoolAid.
#     While this starts with DEMO-, the server runs in demo/simulation mode.
LICENSE_API_KEY=DEMO-0000-0000-0000

